<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE score-partwise PUBLIC
    "-//Recordare//DTD MusicXML 3.1 Partwise//EN"
    "http://www.musicxml.org/dtds/partwise.dtd">
<score-partwise version="3.1">
  <work>
    <work-title>Der Tod und das Mädchen – Etwas geschwinder</work-title>
  </work>

  <identification>
    <creator type="composer">Franz Schubert</creator>
    <creator type="poet">Claudius</creator>
  </identification>

  <part-list>
    <score-part id="P1">
      <part-name>Singstimme</part-name>
    </score-part>
    <score-part id="P2">
      <part-name>Pianoforte</part-name>
    </score-part>
  </part-list>

  <!-- ========================================================= -->
  <!-- ====================== VOCAL PART ======================== -->
  <!-- ========================================================= -->

  <part id="P1">
    <measure number="1">
      <attributes>
        <divisions>2</divisions>
        <key>
          <fifths>-1</fifths>
        </key>
        <time>
          <beats>4</beats>
          <beat-type>4</beat-type>
        </time>
        <clef>
          <sign>G</sign>
          <line>2</line>
        </clef>
      </attributes>
      <direction placement="above">
        <direction-type>
          <metronome>
            <beat-unit>dotted-quarter</beat-unit>
            <per-minute>54</per-minute>
          </metronome>
        </direction-type>
      </direction>

      <!-- Vocal entrance "Vorüber, ach vorüber!" -->
      <note>
        <pitch><step>F</step><octave>5</octave></pitch>
        <duration>2</duration>
        <lyric><text>Vor-</text></lyric>
      </note>
      <note>
        <pitch><step>E</step><alter>-1</alter><octave>5</octave></pitch>
        <duration>2</duration>
        <lyric><text>ü-</text></lyric>
      </note>
      <note>
        <pitch><step>D</step><octave>5</octave></pitch>
        <duration>4</duration>
        <lyric><text>ber,</text></lyric>
      </note>
    </measure>

    <measure number="2">
      <note>
        <pitch><step>F</step><octave>5</octave></pitch>
        <duration>2</duration>
        <lyric><text>ach</text></lyric>
      </note>
      <note>
        <pitch><step>E</step><alter>-1</alter><octave>5</octave></pitch>
        <duration>2</duration>
        <lyric><text>vor-</text></lyric>
      </note>
      <note>
        <pitch><step>D</step><octave>5</octave></pitch>
        <duration>4</duration>
        <lyric><text>ü-</text></lyric>
      </note>
    </measure>

    <measure number="3">
      <note>
        <pitch><step>C</step><octave>5</octave></pitch>
        <duration>4</duration>
        <lyric><text>ber!</text></lyric>
      </note>
    </measure>
  </part>

  <!-- ========================================================= -->
  <!-- ====================== PIANO PART ======================== -->
  <!-- ========================================================= -->

  <part id="P2">
    <measure number="1">
      <attributes>
        <divisions>2</divisions>
        <key>
          <fifths>-1</fifths>
        </key>
        <time>
          <beats>4</beats>
          <beat-type>4</beat-type>
        </time>
        <clef>
          <sign>G</sign>
          <line>2</line>
        </clef>
      </attributes>

      <!-- Piano RH opening repeated chords -->
      <note>
        <chord/> 
        <pitch><step>A</step><octave>4</octave></pitch>
        <duration>2</duration>
      </note>
      <note>
        <pitch><step>C</step><octave>5</octave></pitch>
        <duration>2</duration>
      </note>
      <note>
        <pitch><step>E</step><octave>5</octave></pitch>
        <duration>2</duration>
      </note>
    </measure>

    <measure number="1" implicit="yes">
      <clef>
        <sign>F</sign>
        <line>4</line>
      </clef>
      <!-- LH arpeggiated pattern (approx.) -->
      <note>
        <pitch><step>A</step><octave>2</octave></pitch>
        <duration>2</duration>
      </note>
      <note>
        <pitch><step>E</step><octave>3</octave></pitch>
        <duration>2</duration>
      </note>
      <note>
        <pitch><step>A</step><octave>3</octave></pitch>
        <duration>2</duration>
      </note>
    </measure>
  </part>
</score-partwise>
